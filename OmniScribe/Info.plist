<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- ============================================================ -->
	<!-- CRITICAL: Hides the app from the Dock and Application Switcher -->
	<!-- ============================================================ -->
	<key>LSUIElement</key>
	<true/>

	<!-- ============================================================ -->
	<!-- Privacy usage strings (required by macOS / App Store review) -->
	<!-- ============================================================ -->
	<key>NSMicrophoneUsageDescription</key>
	<string>OmniScribe uses the microphone to record your voice and transcribe speech to text.</string>

	<key>NSSpeechRecognitionUsageDescription</key>
	<string>OmniScribe uses speech recognition to transcribe your recorded voice into text.</string>

	<!-- ============================================================ -->
	<!-- Bundle metadata                                               -->
	<!-- ============================================================ -->
	<key>CFBundleName</key>
	<string>OmniScribe</string>

	<key>CFBundleDisplayName</key>
	<string>OmniScribe</string>

	<key>CFBundleIdentifier</key>
	<string>com.omniscribe.app</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleVersion</key>
	<string>1</string>

	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>

	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- ============================================================ -->
	<!-- Minimum macOS version: Ventura (13.0)                        -->
	<!-- ============================================================ -->
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>

	<!-- ============================================================ -->
	<!-- Prevent accidental termination                                -->
	<!-- ============================================================ -->
	<key>NSSupportsAutomaticTermination</key>
	<false/>

	<key>NSSupportsSuddenTermination</key>
	<false/>

	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2025 OmniScribe. All rights reserved.</string>

</dict>
</plist>
